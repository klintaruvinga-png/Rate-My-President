# Local development environment for the Rate My President server.
# Copy to `.env` and fill in. In production (Railway) these are injected by the
# platform — you do NOT need this file there.

# Required: Postgres connection string. For local dev, run Postgres and set:
#   docker run -d --name rmp-pg -p 5432:5432 -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=rmp postgres:16
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rmp

# Optional: CORS allowed origins (comma-separated). In production set this to
# your frontend origin(s), e.g. https://rmp.xyz,https://www.rmp.xyz
# If unset, localhost + known Railway/Vercel domains are allowed.
ALLOWED_ORIGINS=

# Optional: enable if running behind a reverse proxy (e.g. Railway's proxy)
TRUST_PROXY=false

# Optional: port (Railway injects PORT; defaults to 3001 locally)
PORT=3001
