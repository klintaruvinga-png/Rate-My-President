# RMP demo — API configuration
# Copy to .env.local and set the deployed backend URL.
# The demo calls the Express backend (server/) at <VITE_API_BASE_URL>.
# Do NOT include /api in this value; the client appends it.

# Production (Railway backend, once deployed + custom domain optional):
VITE_API_BASE_URL=https://rmp-backend.railway.app

# Local dev (backend running on :3000):
# VITE_API_BASE_URL=http://localhost:3000
